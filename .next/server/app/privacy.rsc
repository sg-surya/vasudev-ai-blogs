9:["$","strong",null,{"children":"Google Analytics"}]
a:["$","h2",null,{"children":"How We Use Your Information"}]
b:["$","p",null,{"children":"We use the information we collect for the following purposes:"}]
c:["$","ul",null,{"children":[["$","li",null,{"children":[["$","strong",null,{"children":"Communication:"}]," To respond to your inquiries when you contact us or sign up for updates. We will use your email address only to provide the information or services you requested."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Site Improvement:"}]," To analyze website usage and improve our content, features, and user experience. For example, Google Analytics helps us understand which articles are most popular."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Advertising:"}]," We may use your data in accordance with the preferences of third-party ad services (see below). However, we do ",["$","strong",null,{"children":"not"}]," sell or rent your personal information to anyone."]}]]}]
d:["$","h2",null,{"children":"Third-Party Services"}]
e:["$","p",null,{"children":"We use third-party vendors to help deliver and analyze our content, and these vendors may collect some information. For example:"}]
f:["$","ul",null,{"children":[["$","li",null,{"children":[["$","strong",null,{"children":"Google AdSense and Google Analytics:"}]," We display ads via Google AdSense and use Google Analytics for traffic analysis. Google may place cookies or use other identifiers on your device. Neither Vasudev AI Chronicles nor Google will use this data to personally identify you; it is used to optimize ads and content. For details, please see Google’s Privacy Policy at ",["$","a",null,{"href":"https://policies.google.com/privacy","target":"_blank","rel":"noopener noreferrer","children":"policies.google.com/privacy"}],"."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Other Vendors:"}]," We may partner with other advertising networks or analytics services in the future. We will notify you of any additional third parties and provide links to their privacy policies as required by law."]}]]}]
10:["$","h2",null,{"children":"Cookies and Tracking"}]
11:["$","p",null,{"children":"We use cookies, web beacons, and similar technologies to collect usage data. Cookies are small files stored on your device that remember certain preferences (like language) and help us provide a smoother experience. We also use cookies from third parties (e.g. Google) to help with analytics and ad personalization. Our Cookie Policy gives more detail on the cookies we use and how you can control them."}]
12:["$","h2",null,{"children":"Data Security"}]
13:["$","p",null,{"children":"We implement reasonable security measures to protect your data from unauthorized access or disclosure. However, no internet transmission is 100% secure. We cannot guarantee absolute protection, so you provide information at your own risk. If you suspect any unauthorized activity on our site, please contact us immediately."}]
14:["$","h2",null,{"children":"Your Rights"}]
15:["$","p",null,{"children":"Depending on your jurisdiction, you may have rights regarding your personal data (such as the right to access, correct, or delete your information). We will honor applicable laws. If you have questions about your data or wish to exercise these rights, please reach out using the contact information below."}]
16:["$","h2",null,{"children":"Children’s Privacy"}]
17:["$","p",null,{"children":"Our site is intended for general audiences and does not knowingly collect personal information from children under 13. If you are a parent or guardian and believe your child has submitted data to us, please contact us, and we will promptly remove that information."}]
18:["$","h2",null,{"children":"Policy Changes"}]
19:["$","p",null,{"children":"We may update this Privacy Policy periodically (for example, to comply with new regulations or add third-party services). We will post the revised date at the top of this page. Please review this policy regularly to stay informed about how we are protecting your information."}]
1a:["$","h2",null,{"children":"Contact"}]
